# Place this file inside the /performyx/ folder itself
# (i.e. alongside your built index.html, assets/, etc.)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /performyx/

  # If the request is for a real file or directory, serve it directly
  # (this lets your actual JS/CSS/image assets load normally)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, it's a client-side route (e.g. /performyx/cart, /performyx/checkout)
  # so send everything to index.html and let React Router handle it
  RewriteRule ^ index.html [L]
</IfModule>

# Optional but recommended: prevent caching issues after each deploy
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Optional: gzip compression for faster loads
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
